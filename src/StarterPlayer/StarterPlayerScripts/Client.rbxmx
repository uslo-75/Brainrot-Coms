		</Properties>
		<Item class="ModuleScript" referent="RBX34BF966ECAB948D59085416AC6FBA02F">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[local ToolHandler = {}
ToolHandler.__index = ToolHandler

function ToolHandler.new(player)
	assert(player and player:IsA("Player"), "Player invalide")

	local self = setmetatable({}, ToolHandler)

	self.Player = player
	self.Character = player.Character or player.CharacterAdded:Wait()

	-- Callbacks
	self.OnEquipped = nil      -- function(tool)
	self.OnUnequipped = nil    -- function(tool)
	self.OnActivated = nil     -- function(tool)

	self._connections = {}
	self._toolConnections = {}

	self:_watchCharacter(self.Character)

	table.insert(self._connections,
		player.CharacterAdded:Connect(function(char)
			self.Character = char
			self:_watchCharacter(char)
		end)
	)

	return self
end

-- ================= CHARACTER =================

function ToolHandler:_watchCharacter(character)

	table.insert(self._connections,
		character.ChildAdded:Connect(function(tool)
			if tool:IsA("Tool") then
				self:_connectTool(tool)
				if self.OnEquipped then
					self.OnEquipped(tool)
				end
			end
		end)
	)

	table.insert(self._connections,
		character.ChildRemoved:Connect(function(tool)
			if tool:IsA("Tool") then
				self:_disconnectTool(tool)
				if self.OnUnequipped then
					self.OnUnequipped(tool)
				end
			end
		end)
	)
end

-- ================= TOOL =================

function ToolHandler:_connectTool(tool)
	if self._toolConnections[tool] then return end

	self._toolConnections[tool] = tool.Activated:Connect(function()
		if self.OnActivated then
			self.OnActivated(tool)
		end
	end)
end

function ToolHandler:_disconnectTool(tool)
	local conn = self._toolConnections[tool]
	if conn then
		conn:Disconnect()
		self._toolConnections[tool] = nil
	end
end

-- ================= CLEANUP =================

function ToolHandler:Destroy()
	for _, conn in ipairs(self._connections) do
		conn:Disconnect()
	end

	for _, conn in pairs(self._toolConnections) do
		conn:Disconnect()
	end

	table.clear(self)
end

return ToolHandler]]></ProtectedString>
