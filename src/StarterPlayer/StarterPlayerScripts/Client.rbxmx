<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
	<Meta name="ExplicitAutoJoints">true</Meta>
	<External>null</External>
	<External>nil</External>
	<Item class="LocalScript" referent="RBXA57BA600345D43A7B1538891550022E8">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local ToolHandler = require(script.ToolHandler)
local player = game.Players.LocalPlayer
local RP = game:GetService("ReplicatedStorage")
local ToolEvent = RP:WaitForChild("Events"):WaitForChild("RemoteEvents"):WaitForChild("ToolEvent")

local handler = ToolHandler.new(player)

local function ToolAsset(tool, b)
	local _name = tool.Name
	local _module = script:WaitForChild("Tools"):FindFirstChild(_name)
	
	if _module then
		_module = require(_module)
		
		if b then
			_module.Equip(player, tool)
		else
			_module.Unequipped(player, tool)
		end
		
	end
end

handler.OnEquipped = function(tool)
	ToolAsset(tool, true)
end

handler.OnUnequipped = function(tool)
	ToolAsset(tool, false)
end

handler.OnActivated = function(tool)
	ToolEvent:FireServer("Active", tool.Name)
end]]></ProtectedString>
			<bool name="Disabled">false</bool>
			<Content name="LinkedSource"><null></null></Content>
			<token name="RunContext">0</token>
			<string name="ScriptGuid">{3DE8055F-4B8A-4213-AFEB-C5821DB467FA}</string>
			<BinaryString name="AttributesSerialize"></BinaryString>
			<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
			<bool name="DefinesCapabilities">false</bool>
			<string name="Name">Client</string>
