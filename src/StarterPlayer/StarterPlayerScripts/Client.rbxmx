			<Item class="ModuleScript" referent="RBX941C30E388E84373B0849322C4ED76D6">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[return {
	Equip = function(player : Player, tool)
		tool.Handle.Equip:Play()
	end,
	Unequipped = function(player : Player, tool)
		tool.Handle.UnEquip:Play()
	end,
}]]></ProtectedString>
